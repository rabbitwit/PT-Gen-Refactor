name = "pt-gen-refactor"
main = "worker/index.js"
compatibility_date = "2025-08-27"

[assets]
directory = "./frontend/dist"
binding = "ASSETS"

# 环境变量（可选）
# 注意：敏感信息（API_KEY、TMDB_API_KEY、Cookie、TRAKT_API_CLIENT_ID、AUTH_SECRET 等）应使用 Secrets，不要写在这里
# 使用命令：wrangler secret put VARIABLE_NAME
# LOG_LEVEL：日志级别（debug | info | warn | error | none）
# - debug: 输出所有日志（开发环境推荐）
# - info:  输出一般信息（默认）
# - warn:  只输出警告和错误
# - error: 只输出错误
# - none:  不输出任何日志
[vars]
AUTHOR = "Hares"
LOG_LEVEL = "none"
ENABLED_CACHE = "true"
#API_KEY = "your_api_key"
#TMDB_API_KEY = "your_tmdb_api_key"
#DOUBAN_COOKIE = 'your_douban_cookie'
#QQ_COOKIE = 'your_qq_music_cookie'
#TRAKT_API_CLIENT_ID = "your_trakt_api_client_id"
#TRAKT_APP_NAME = "your_trakt_api_app_name"
#AUTH_SECRET = "your_auth_secret"  # HMAC 签名认证密钥（前后端必须一致）


# R2 存储桶配置（可选，选择一种缓存方式即可） 如需使用 R2 存储桶缓存删除参数前的 # 符号
#[[r2_buckets]]
#binding = "R2_BUCKET"
#bucket_name = "pt-gen-cache"

# D1 数据库配置（可选，选择一种缓存方式即可） 如需使用 D1 数据库缓存删除参数前的 # 符号
#[[d1_databases]]
#binding = "DB"
#database_name = "pt-gen-cache"
#database_id = ""

# 日志配置
#[observability]
#[observability.logs]
#enabled = true
#head_sampling_rate = 1
#invocation_logs = true